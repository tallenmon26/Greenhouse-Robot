import serial
import time
import sys
import tty
import termios
import select

SERIAL_PORT = '/dev/ttyACM0' 
BAUD_RATE = 115200

try:
    esp32 = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=0.1)
    time.sleep(2) 
    print("Connected to ESP32!")
except serial.SerialException as e:
    print(f"Error: Could not connect to ESP32: {e}")
    sys.exit(1)

# Dictionary mapping keyboard keys to your specific ESP32 serial commands
key_mapping = {
    'w': b"FORWARD\n",
    's': b"BACKWARD\n",
    'a': b"LEFT\n",
    'd': b"RIGHT\n",
    'i': b"UP\n",
    'k': b"DOWN\n",
    'f': b"FAN\n",
    ' ': b"STOP\n"  # Spacebar to hit the brakes
}

# --- Vertical System Variables ---
target_height = 0.0
current_height = 0.0
is_adjusting_height = False
height_tolerance = 0.1  
last_auto_cmd = b""
last_auto_cmd_time = 0

# --- Manual Control Watchdog Variables ---
last_manual_cmd = b"STOP\n"
last_manual_cmd_time = 0

def get_key():
    """NON-BLOCKING key reader so the buffer flush can run constantly!"""
    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    try:
        tty.setraw(sys.stdin.fileno())
        # Check if a key was pressed, but only wait 0.05 seconds!
        if select.select([sys.stdin], [], [], 0.05)[0]:
            ch = sys.stdin.read(1)
        else:
            ch = '' 
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
    return ch

print("\n=== Manual Robot Control ===")
print(" W = Forward  |  S = Backward")
print(" A = Left     |  D = Right")
print(" I = UP       |  K = DOWN")
print(" F = FAN      |  H = Set Target Height")
print(" [Spacebar] = STOP")
print(" Q = Quit Program")
print("============================\n")

try:
    while True:
        # 1. READ INCOMING SERIAL DATA
        while esp32.in_waiting > 0:
            try:
                line = esp32.readline().decode('utf-8').strip()
                if line:
                    if "LIDAR Distance:" in line:
                        try:
                            # 1.5 Foot (18 inches) Ground Offset!
                            raw_lidar_feet = float(line.split(":")[1].strip())
                            current_height = raw_lidar_feet + 1.5 
                            
                            # THE FIX: We tell the terminal to print our new 'current_height' variable,
                            # instead of just printing the raw ESP32 string!
                            if is_adjusting_height:
                                print(f"\rAuto-Adjusting... Current: {current_height:.2f} ft | Target: {target_height:.2f} ft        ", end="", flush=True)
                            else:
                                print(f"\rTrue Ground Height: {current_height:.2f} ft                            ", end="", flush=True)
                                
                        except ValueError:
                            pass
                    else:
                        # If the ESP32 sends something else (like "Connected"), print it normally
                        print(f"\r{line}                            ", end="", flush=True)

            except UnicodeDecodeError:
                pass 
                
        # --- THE MASTER CLOCK ---
        # If this isn't in the main loop, the software watchdog fails!
        current_time = time.time()
        
        # --- AUTO-HEIGHT CONTROLLER ---
        if is_adjusting_height:
            if current_height < target_height - height_tolerance:
                if last_auto_cmd != b"UP\n" or (current_time - last_auto_cmd_time > 0.2):
                    esp32.write(b"UP\n")
                    last_auto_cmd = b"UP\n"
                    last_auto_cmd_time = current_time
                    
            elif current_height > target_height + height_tolerance:
                if last_auto_cmd != b"DOWN\n" or (current_time - last_auto_cmd_time > 0.2):
                    esp32.write(b"DOWN\n")
                    last_auto_cmd = b"DOWN\n"
                    last_auto_cmd_time = current_time
                    
            else:
                esp32.write(b"STOP\n")
                is_adjusting_height = False
                last_auto_cmd = b""
                print(f"\n[SYSTEM] Target height of {target_height} reached! Resuming manual control.\n")
        
        # 2. HANDLE KEYBOARD INPUT
        key = get_key().lower() 
        if key == '': 
            # THE FIX: Python Watchdog! 
            # If no key is pressed for 0.2s, and we aren't auto-adjusting, kill the motors!
            if not is_adjusting_height and last_manual_cmd != b"STOP\n":
                if current_time - last_manual_cmd_time > 0.2:
                    esp32.write(b"STOP\n")
                    last_manual_cmd = b"STOP\n"
            continue 
            
        if key == 'h':
            esp32.write(b"STOP\n") 
            is_adjusting_height = False 
            print("\n")
            try:
                user_input = input("Enter target height: ")
                target_height = float(user_input)
                is_adjusting_height = True
                print(f"[SYSTEM] Auto-Height engaged. Moving to {target_height}...")
            except ValueError:
                print("[ERROR] Invalid number. Auto-Height cancelled.")
            continue
        
        if key == 'q':
            print("\n\nQuitting...")
            esp32.write(b"STOP\n")
            break
            
        if key in key_mapping:
            if key in ['i', 'k', ' ']:
                is_adjusting_height = False
                
            command = key_mapping[key]
            esp32.write(command)
            
            # Reset the Python Watchdog timer every time a key is read
            last_manual_cmd = command
            last_manual_cmd_time = current_time

except KeyboardInterrupt:
    print("\n\nForce Quit detected.")
finally:
    esp32.write(b"STOP\n")
    esp32.close()
    print("Serial connection closed. Motors stopped.")
